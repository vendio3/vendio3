--// 8. Isolation Architecture Engine Loops

-- Loop 1: Auto Lemon Picker
task.spawn(function()
    while true do
        if AutoFruit then
            local HRP = GetHRP()
            if HRP then
                local Fruits = {}
                for _, tycoon in ipairs(workspace:GetChildren()) do
                    local constant = tycoon:FindFirstChild("Constant")
                    if constant then
                        local trees = constant:FindFirstChild("Trees")
                        if trees then
                            for _, obj in ipairs(trees:GetDescendants()) do
                                if obj.Name == "Fruit" then
                                    table.insert(Fruits, obj)
                                end
                            end
                        end
                    end
                end

                for _, fruit in ipairs(Fruits) do
                    if not AutoFruit then break end
                    if fruit and fruit.Parent then
                        local part = GetFruitPart(fruit)
                        if part then
                            HRP.CFrame = part.CFrame + Vector3.new(0,2,0)
                            local cd = fruit:FindFirstChildOfClass("ClickDetector")
                                or part:FindFirstChildOfClass("ClickDetector")
                                or fruit:FindFirstChild("ClickDetector", true)

                            if cd then fireclickdetector(cd) end
                            task.wait(0.05)
                        end
                    end
                end
            end
        end
        task.wait(0.05)
    end
end)

-- Loop 2: Spam Upgrades Binary Search Optimizer Loop
task.spawn(function()
    while true do
        task.wait(0.3)
        if SpammingUpgrades then
            for i = 1, #cachedUpgradeRemotes do
                if not SpammingUpgrades then break end
                local remote = cachedUpgradeRemotes[i]
                
                coroutine.wrap(function()
                    local success, result = pcall(function() return remote:InvokeServer(100) end)
                    if success and result == true then return end
                    
                    local low, high = 1, 99
                    while low <= high do
                        if not SpammingUpgrades then break end
                        local mid = math.floor((low + high) / 2)
                        local testSuccess, testResult = pcall(function() return remote:InvokeServer(mid) end)
                        
                        if testSuccess and testResult == true then
                            low = mid + 1
                        else
                            high = mid - 1
                        end
                        task.wait()
                    end
                end)()
            end
        end
    end
end)

-- Loop 3: Optimized Controlled Teleport Pad Loop (With Dynamic Target Array Refreshes)
task.spawn(function()
    while true do
        task.wait(TP_DELAY)
        
        if AutoTP then
            local Character = LocalPlayer.Character
            local HRP = Character and Character:FindFirstChild("HumanoidRootPart")
            local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
            
            if HRP and Humanoid and Humanoid.Health > 0 then
                local buttons = cachedButtons 
                if #buttons > 0 then
                    if CurrentIndex > #buttons then 
                        CurrentIndex = 1 
                        cacheButtonsFunc() 
                    end
                    
                    local button = buttons[CurrentIndex]
                    
                    if button and button.Parent and button:IsA("BasePart") then
                        Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
                        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
                        
                        local _, currentRotationY = HRP.CFrame:ToEulerAnglesXYZ()
                        local dropHeight = (button.Size.Y / 2) + 2.5
                        
                        HRP.CFrame = CFrame.new(button.Position + Vector3.new(0, dropHeight, 0)) * CFrame.Angles(0, currentRotationY, 0)
                        HRP.AssemblyLinearVelocity = Vector3.new(0, -60, 0)
                        Humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
                        
                        task.wait(0.03) 
                        Humanoid:ChangeState(Enum.HumanoidStateType.Landed)
                        
                        local touchPart = Character:FindFirstChild("RightFoot") or Character:FindFirstChild("Right Leg") or HRP
                        if touchPart then
                            pcall(function()
                                firetouchinterest(touchPart, button, 0)
                                firetouchinterest(touchPart, button, 1)
                            end)
                        end
                    end
                    CurrentIndex = CurrentIndex + 1
                end
            end
        end
    end
end)

-- Loop 4: New Controlled Remote Spam Loop (Network Protected & Batched)
task.spawn(function()
    while true do
        task.wait(SPAM_DELAY)
        
        if SpammingPurchases then
            for i = 1, #cachedPurchaseRemotes do
                if not SpammingPurchases then break end 
                
                local remote = cachedPurchaseRemotes[i]
                if remote and remote.Parent then
                    task.defer(function()
                        pcall(function()
                            remote:InvokeServer(false)
                        end)
                    end)
                end
                
                -- Process micro batches based on size of 10 to clear network pipes
                if i % BATCH_SIZE == 0 then
                    task.wait(0.01)
                end
            end
        end
    end
end)
