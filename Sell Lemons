--// 1. Unified Master Tycoon Finder
local Tycoon = nil
local function findMyTycoon()
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:FindFirstChild("Owner") and tostring(obj.Owner.Value) == LocalPlayer.Name then
            return obj
        elseif obj:FindFirstChild("OwnerId") and tonumber(obj.OwnerId.Value) == LocalPlayer.UserId then
            return obj
        elseif string.find(string.lower(obj.Name), string.lower(LocalPlayer.Name)) then
            return obj
        end
    end
    
    local tycoonsFolder = workspace:FindFirstChild("Tycoons") or workspace:FindFirstChild("AllTycoons")
    if tycoonsFolder then
        for _, obj in ipairs(tycoonsFolder:GetChildren()) do
            if obj:FindFirstChild("Owner") and tostring(obj.Owner.Value) == LocalPlayer.Name then
                return obj
            elseif obj:FindFirstChild("OwnerId") and tonumber(obj.OwnerId.Value) == LocalPlayer.UserId then
                return obj
            elseif string.find(string.lower(obj.Name), string.lower(LocalPlayer.Name)) then
                return obj
            end
        end
    end
    return nil
end

