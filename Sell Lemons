--// 3. Automation Utility Helper Subroutines
local function GetHRP()
    local Character = LocalPlayer.Character
    return Character and Character:FindFirstChild("HumanoidRootPart")
end

local function GetFruitPart(fruit)
    if fruit:IsA("BasePart") then return fruit end
    return fruit:FindFirstChildWhichIsA("BasePart", true)
end

local function cacheUpgradeRemotesFunc()
    table.clear(cachedUpgradeRemotes)
    if Tycoon and Tycoon:FindFirstChild("Purchases") then
        for _, name in ipairs(upgradeLocations) do
            local targetFolder = Tycoon.Purchases:FindFirstChild(name)
            if targetFolder then
                pcall(function()
                    local upgradeRemote = targetFolder:WaitForChild(name, 1):WaitForChild(name, 1):WaitForChild("Upgrade", 1)
                    if upgradeRemote and upgradeRemote:IsA("RemoteFunction") then
                        table.insert(cachedUpgradeRemotes, upgradeRemote)
                    end
                end)
            end
        end
    end
end

local function cacheAllPurchasesFunc()
    table.clear(cachedPurchaseRemotes)
    if Tycoon and Tycoon:FindFirstChild("Purchases") then
        for _, descendant in ipairs(Tycoon.Purchases:GetDescendants()) do
            if descendant.Name == "Purchase" and descendant:IsA("RemoteFunction") then
                table.insert(cachedPurchaseRemotes, descendant)
            end
        end
    end
end

local function cacheButtonsFunc()
    table.clear(cachedButtons)
    if Tycoon then
        for _, obj in ipairs(Tycoon:GetDescendants()) do
            if obj.Name == "Button" and obj:IsA("BasePart") and obj.Parent then
                table.insert(cachedButtons, obj)
            end
        end
        table.sort(cachedButtons, function(a, b) return a:GetFullName() < b:GetFullName() end)
    end
end

